---
const path = Astro.url.pathname;
const links = [
	{ href: '/', label: 'ホーム' },
	{ href: '/structure/', label: 'ディレクトリ構成' },
];
const isActive = (href: string) =>
	href === '/' ? path === '/' : path.startsWith(href);
---

<nav class="site-nav">
	<ul>
		{links.map((link) => (
			<li>
				<a href={link.href} class={isActive(link.href) ? 'active' : ''}>
					{link.label}
				</a>
			</li>
		))}
	</ul>
</nav>
